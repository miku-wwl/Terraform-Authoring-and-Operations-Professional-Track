# AWS CLI credentials 示例文件。
# 真实默认位置通常是 ~/.aws/credentials。
# 真实项目不要把真正的 credentials 提交到 Git。

# credentials 文件里的 profile 名直接写成 [<name>]。
# 注意这里不是 [profile lab]，而是 [lab]。
[lab]

# access key id：访问 AWS API 的凭证 ID。
# Lab/LocalStack 使用 test；真实项目不要硬编码真实 key。
aws_access_key_id = test

# secret access key：访问 AWS API 的密钥。
# Lab/LocalStack 使用 test；真实项目应使用 SSO、Role、OIDC 或 CI Secret。
aws_secret_access_key = test

