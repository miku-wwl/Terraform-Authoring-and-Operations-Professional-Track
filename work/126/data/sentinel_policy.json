{
  "platform": "HCP Terraform",
  "feature": "Sentinel",
  "availability": {
    "requires_paid_plan": true,
    "example_plan": "Team and Governance trial"
  },
  "workspace": {
    "name": "sentinel"
  },
  "policy_set": {
    "name": "sentinel-policy-set",
