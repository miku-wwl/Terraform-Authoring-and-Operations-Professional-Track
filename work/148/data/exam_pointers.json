  ],
  "import_targets": [
    {
      "resource_type": "aws_instance",
      "resource_name": "test",
      "id_kind": "instance id",
      "example_id": "i-0123456789abcdef0",
      "conflicting_arguments": [
        "ipv6_address_count",
        "ipv6_addresses"
      ]
    },
    {
      "resource_type": "aws_iam_policy",
      "resource_name": "readonly",
      "id_kind": "policy arn",
      "example_id": "arn:aws:iam::123456789012:policy/ReadOnlyTeamPolicy",
      "conflicting_arguments": []
    },
    {
      "resource_type": "aws_security_group",
      "resource_name": "web",
      "id_kind": "security group id",
      "example_id": "sg-0123456789abcdef0",
      "conflicting_arguments": []
    }
  ],
  "commands": {
    "generate_config_out": "terraform plan -generate-config-out=generated.tf",
    "import_block": "import { to = aws_instance.test id = \"i-0123456789abcdef0\" }"
  }
