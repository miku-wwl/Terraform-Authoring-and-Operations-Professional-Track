  "provider_alias_workflow": [
    {
      "order": 1,
      "location": "root",
      "action": "define default aws provider"
    },
    {
      "order": 2,
      "location": "root",
      "action": "define aliased aws provider, for example aws.mumbai"
    },
    {
      "order": 3,
      "location": "child",
      "action": "declare configuration_aliases in required_providers"
    },
    {
      "order": 4,
      "location": "root",
      "action": "pass providers map to module block"
    },
    {
      "order": 5,
      "location": "child",
      "action": "set provider meta-argument on resources that need alias"
    }
  ],
  "data_sources": [
    {
      "name": "aws_ami",
      "requires_filters": true
    },
    {
      "name": "aws_subnet",
      "requires_filters": true
    },
    {
