{
  "hostname": "app.terraform.io",
  "organization": "kplabs-terraform-learning",
  "workspace": {
    "name": "cli-driven-workflow",
    "execution_mode": "remote"
  },
  "authentication": {
    "login_command": "terraform login app.terraform.io",
    "credentials_file": "~/.terraform.d/credentials.tfrc.json",
    "token_storage": "plaintext",
    "recommended_expiration_minutes": 60,
    "commit_credentials_file": false
  },
  "terraform_versions": {
    "local": "1.9.1",
    "remote": "1.9.7"
  },
  "resource": {
    "type": "time_sleep",
    "wait_seconds": 10
  },
  "steps": [
    {
      "order": 1,
      "command": "terraform login app.terraform.io",
      "purpose": "Authenticate the local CLI to HCP Terraform"
    },
    {
      "order": 2,
      "command": "terraform init",
      "purpose": "Initialize the HCP Terraform cloud integration"
    },
    {
      "order": 3,
      "command": "terraform plan",
      "purpose": "Trigger a remote plan from the local CLI"
    },
    {
      "order": 4,
      "command": "terraform apply",
      "purpose": "Confirm and execute the remote apply"
    }
  ]
}
