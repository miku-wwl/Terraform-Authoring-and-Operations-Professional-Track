{
  "log_levels": ["ERROR", "WARN", "INFO", "DEBUG", "TRACE"],
  "log_file": "terraform-debug.log",
  "shells": {
    "windows_cmd": {
      "set_log_prefix": "set TF_LOG=",
      "set_path_prefix": "set TF_LOG_PATH=",
      "clear_log": "set TF_LOG=",
      "clear_path": "set TF_LOG_PATH="
    },
    "powershell": {
      "set_log_prefix": "$env:TF_LOG = ",
      "set_path_prefix": "$env:TF_LOG_PATH = ",
      "clear_log": "Remove-Item Env:TF_LOG",
      "clear_path": "Remove-Item Env:TF_LOG_PATH"
    },
    "linux_macos": {
      "set_log_prefix": "export TF_LOG=",
      "set_path_prefix": "export TF_LOG_PATH=",
      "clear_log": "unset TF_LOG",
      "clear_path": "unset TF_LOG_PATH"
    }
  }
}
