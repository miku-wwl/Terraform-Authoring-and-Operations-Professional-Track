{
  "organization": "example-kplabs-org",
  "project": "Terraform Learning Project",
  "workspaces": [
    {
      "name": "kplabs-terraform-learning",
      "workflow": "vcs",
      "repository": "demo-kplabs-user/kplabs-terraform-learning",
      "branch": "main",
      "working_directory": "/",
      "terraform_version": "1.11.0",
      "auto_apply": false,
      "variables": [
        {
          "key": "AWS_ACCESS_KEY_ID",
          "category": "env",
          "sensitive": true,
          "purpose": "aws access key for remote run"
        },
        {
          "key": "AWS_SECRET_ACCESS_KEY",
          "category": "env",
          "sensitive": true,
          "purpose": "aws secret key for remote run"
        },
        {
          "key": "AWS_REGION",
          "category": "env",
          "sensitive": false,
          "value": "us-east-1",
          "purpose": "aws region for remote run"
        },
        {
          "key": "instance_type",
          "category": "terraform",
          "sensitive": false,
          "value": "t2.micro",
          "purpose": "example tf variable"
        }
      ],
      "latest_run": {
        "source": "vcs push",
        "plan_status": "planned_and_finished",
        "apply_status": "manual_confirmation_required",
        "final_action": "discarded",
        "discard_reason": "apply not required"
      }
    },
    {
      "name": "network-sandbox",
      "workflow": "cli",
      "repository": null,
      "branch": null,
      "working_directory": "network",
      "terraform_version": "1.11.0",
      "auto_apply": false,
      "variables": [
        {
          "key": "environment",
          "category": "terraform",
          "sensitive": false,
          "value": "sandbox",
          "purpose": "environment name"
        }
      ],
      "latest_run": {
        "source": "local cli",
        "plan_status": "not_started",
        "apply_status": "not_started",
        "final_action": "none",
        "discard_reason": null
      }
    }
  ]
}