# AWS CLI credentials 示例文件。
# 真实默认位置通常是 ~/.aws/credentials。
# 真实项目不要把真正的 credentials 提交到 Git。

# credentials 文件里的 profile 名直接写成 [lab]，不是 [profile lab]。
[lab]
aws_access_key_id = test     # LocalStack 测试 access key。
aws_secret_access_key = test # LocalStack 测试 secret key。

# audit 使用同样的 LocalStack 测试凭证。
# 注意：LocalStack 下不同测试 key 不一定体现为不同 STS 身份。
# 本 lab 用 output=json/text 的差异来观察 profile 切换。
[audit]
aws_access_key_id = test     # LocalStack 测试 access key。
aws_secret_access_key = test # LocalStack 测试 secret key。

