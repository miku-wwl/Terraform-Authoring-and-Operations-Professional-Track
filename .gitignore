# Local Terraform working directories.
# These are generated by `terraform init` and should not be versioned.
.terraform/

# Dependency lock files:
# In real production Terraform root modules, `.terraform.lock.hcl` should normally be committed
# because it pins provider versions and checksums for teammates and CI.
# This repository contains many disposable `work/N` practice sandboxes; each lab can generate
# its own lock file during exercises, so we ignore it here to keep the training repository clean.
.terraform.lock.hcl

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*
tfplan
*.tfplan

# Terraform provider filesystem mirror directories generated by `terraform providers mirror`.
# In production, mirror contents are usually managed as an external artifact or internal registry,
# not committed into the source repository.
mirror/

# Ignore Terraform CLI configuration files.
# `terraform.rc` / `.terraformrc` may contain local paths such as plugin cache directories.
# For shared guidance, commit an example file instead, not the machine-specific active config.
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout
